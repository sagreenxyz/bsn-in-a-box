---
/**
 * DashboardLayout.astro
 *
 * Full-width widget-based layout used by the main dashboard and progress pages.
 * Contains the primary navigation bar, a notification area for retrieval reminders,
 * and a wide main content area suited for a grid of dashboard widgets.
 */
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `${base}/`, label: 'Dashboard', icon: '⊞' },
  { href: `${base}/progress`, label: 'Progress', icon: '◎' },
  { href: `${base}/concepts`, label: 'Concepts', icon: '⬡' },
  { href: `${base}/patients`, label: 'Patients', icon: '♡' },
  { href: `${base}/tools`, label: 'Tools', icon: '⚙' },
  { href: `${base}/reference`, label: 'Reference', icon: '☰' },
  { href: `${base}/settings`, label: 'Settings', icon: '⊙' },
];

/**
 * Checks if a nav link is the current active route.
 * The dashboard link is only active on the exact root path.
 */
function isActive(href: string): boolean {
  if (href === `${base}/`) {
    return currentPath === `${base}/` || currentPath === base;
  }
  return currentPath.startsWith(href);
}
---

<BaseLayout title={title} description={description}>
  <!-- Top navigation bar -->
  <nav
    class="sticky top-0 z-40 border-b border-slate-700/60 bg-[#060d1c]/95 backdrop-blur-sm"
    style="background-image: linear-gradient(180deg, rgba(6,182,212,0.04) 0%, transparent 100%);"
    aria-label="Primary navigation"
  >
    <div class="mx-auto flex max-w-screen-xl items-center justify-between px-4 py-3">
      <!-- Brand -->
      <a
        href={`${base}/`}
        class="flex items-center gap-2 font-serif text-lg font-bold hover:opacity-80 transition-opacity min-h-[44px]"
        style="background: linear-gradient(135deg, #22d3ee 0%, #a78bfa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        aria-label="BSN in a Box — Home"
      >
        <span aria-hidden="true" class="text-2xl" style="-webkit-text-fill-color: #22d3ee;">⊕</span>
        <span class="hidden sm:inline">BSN in a Box</span>
      </a>

      <!-- Navigation links -->
      <ul class="flex items-center gap-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium transition-all min-h-[44px]',
                isActive(link.href)
                  ? 'bg-teal-900/60 text-teal-300 font-semibold ring-1 ring-inset ring-teal-500/30'
                  : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-100',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              <span aria-hidden="true">{link.icon}</span>
              <span class="hidden md:inline">{link.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- Main content area -->
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 py-8">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-auto border-t border-slate-800/60 px-4 py-6 text-center text-sm text-slate-500">
    <p>
      BSN in a Box — Free, offline-capable nursing education.
      <a
        href="https://github.com/sagreenxyz/bsn-in-a-box"
        class="text-teal-400 hover:text-teal-300 underline"
        target="_blank"
        rel="noopener noreferrer"
      >
        Open source on GitHub
      </a>
      · MIT License
    </p>
  </footer>
</BaseLayout>
