---
/**
 * 404.astro — Not Found page
 *
 * Handles deep-link routing gracefully on GitHub Pages.
 * Tells the student what happened and offers a clear path back home.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Page Not Found"
  description="The page you are looking for could not be found in BSN in a Box."
>
  <main
    id="main-content"
    class="min-h-screen flex flex-col items-center justify-center px-4 text-center"
  >
    <p class="font-mono text-8xl font-bold text-slate-700 mb-4" aria-hidden="true">404</p>
    <h1 class="font-serif text-3xl font-bold text-white mb-4">Page Not Found</h1>
    <p class="text-slate-400 max-w-md leading-relaxed mb-8">
      The page you are looking for could not be found. This sometimes happens with direct links
      to lesson pages — try navigating from the dashboard and your progress will guide you there.
    </p>
    <a
      href={base}
      class="rounded-lg bg-teal-600 px-8 py-3 font-bold text-white hover:bg-teal-500 transition-colors min-h-[44px] inline-flex items-center"
    >
      Go to Dashboard
    </a>
  </main>
</BaseLayout>
