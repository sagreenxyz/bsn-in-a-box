---
/**
 * ToolLayout.astro
 *
 * Centered single-tool layout with breadcrumb navigation.
 * Used by all clinical tools, calculators, and reference components.
 * The tool content is centered on the page with a maximum width appropriate
 * for focused single-tool interaction.
 */
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  /** Breadcrumb trail — array of { label, href } pairs, not including current page. */
  breadcrumbs?: { label: string; href: string }[];
}

const { title, description, breadcrumbs = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <!-- Top bar with breadcrumb -->
  <nav
    class="sticky top-0 z-40 border-b border-slate-700 bg-navy bg-opacity-95 backdrop-blur-sm px-4 py-3"
    aria-label="Breadcrumb navigation"
  >
    <div class="mx-auto flex max-w-4xl items-center gap-2 text-sm">
      <a
        href={base}
        class="text-teal-400 hover:text-teal-300 transition-colors min-h-[44px] flex items-center"
        aria-label="Home"
      >
        Home
      </a>
      {breadcrumbs.map((crumb) => (
        <>
          <span class="text-slate-600" aria-hidden="true">/</span>
          <a
            href={crumb.href}
            class="text-slate-400 hover:text-slate-200 transition-colors min-h-[44px] flex items-center"
          >
            {crumb.label}
          </a>
        </>
      ))}
      <span class="text-slate-600" aria-hidden="true">/</span>
      <span class="text-slate-200 font-medium" aria-current="page">{title}</span>
    </div>
  </nav>

  <!-- Main content: centered, max 4xl width for focused tool interaction -->
  <main id="main-content" class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="font-serif text-3xl font-bold text-white mb-2">{title}</h1>

    <slot />
  </main>
</BaseLayout>
