---
/**
 * progress/index.astro — Student Progress Overview
 *
 * Detailed view of progress across all phases, concept mastery scores,
 * calibration accuracy, and study streak history.
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import NCLEXReadinessMeter from '../../components/assessment/NCLEXReadinessMeter';
---

<DashboardLayout
  title="Progress"
  description="Your BSN in a Box study progress — phase completion, concept mastery, calibration accuracy, and study streak."
>
  <h1 class="font-serif text-3xl font-bold text-white mb-2">Your Progress</h1>
  <p class="text-slate-400 mb-8 max-w-prose">
    Progress in BSN in a Box is never time-based. Advancement is earned exclusively through
    demonstrated competency. Every gate must be passed; every module must be completed. This page
    shows you exactly where you stand and what you have earned.
  </p>

  <!-- Phase progress bars -->
  <section class="mb-10" aria-labelledby="phase-progress-heading">
    <h2 id="phase-progress-heading" class="text-xl font-serif font-bold text-white mb-6">
      Phase Completion
    </h2>
    <div class="space-y-4">
      {[
        { phase: 1, title: 'Foundations of Nursing Practice', modules: 12, completed: 0 },
        { phase: 2, title: 'Intermediate Clinical Practice', modules: 0, completed: 0, locked: true },
        { phase: 3, title: 'Advanced Clinical Nursing', modules: 0, completed: 0, locked: true },
        { phase: 4, title: 'Synthesis and Leadership', modules: 0, completed: 0, locked: true },
      ].map((p) => (
        <div class={`rounded-xl border p-6 ${p.locked ? 'border-slate-800 opacity-50' : 'border-slate-700 bg-slate-900'}`}>
          <div class="flex items-center justify-between mb-3">
            <div>
              <span class="text-xs font-bold uppercase tracking-widest text-slate-500">Phase {p.phase}</span>
              <h3 class="font-serif font-semibold text-white">{p.title}</h3>
            </div>
            {p.locked ? (
              <span class="text-slate-600 text-sm">Locked</span>
            ) : (
              <span class="font-mono text-sm text-teal-400">
                {p.completed}/{p.modules} modules
              </span>
            )}
          </div>
          {!p.locked && (
            <div class="w-full bg-slate-700 rounded-full h-2">
              <div
                class="h-2 rounded-full bg-teal-500 transition-all"
                style={`width: ${p.modules > 0 ? Math.round((p.completed / p.modules) * 100) : 0}%`}
                role="progressbar"
                aria-valuenow={p.completed}
                aria-valuemin={0}
                aria-valuemax={p.modules}
                aria-label={`Phase ${p.phase}: ${p.completed} of ${p.modules} modules completed`}
              ></div>
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- NCLEX Readiness Meter -->
  <section class="mb-10">
    <NCLEXReadinessMeter client:load />
  </section>

  <!-- Concept mastery -->
  <section class="mb-10" aria-labelledby="concept-mastery-heading">
    <h2 id="concept-mastery-heading" class="text-xl font-serif font-bold text-white mb-4">
      Concept Mastery
    </h2>
    <div class="rounded-xl border border-slate-700 bg-slate-900 p-6 text-center text-slate-400">
      <p>Concept mastery scores will appear here after you complete your first quiz.</p>
      <p class="text-sm mt-2">
        Each of the 35 core nursing concepts is scored based on your performance across all
        assessment items that touch that concept.
      </p>
    </div>
  </section>

  <!-- Metacognitive calibration -->
  <section class="mb-10" aria-labelledby="calibration-heading">
    <h2 id="calibration-heading" class="text-xl font-serif font-bold text-white mb-4">
      Metacognitive Calibration
    </h2>
    <div class="rounded-xl border border-slate-700 bg-slate-900 p-6">
      <p class="text-slate-400 leading-relaxed">
        Your metacognitive calibration data will appear here once you have completed your first
        unit assessment. Before each unit begins, you will rate your confidence on each topic.
        After the assessment, the system compares your predictions to your actual performance.
        Over time, this comparison reveals patterns in how accurately you know what you know —
        a skill that is as important in nursing practice as any clinical fact.
      </p>
    </div>
  </section>

  <!-- Study streak -->
  <section aria-labelledby="streak-heading">
    <h2 id="streak-heading" class="text-xl font-serif font-bold text-white mb-4">
      Study Streak
    </h2>
    <div class="rounded-xl border border-slate-700 bg-slate-900 p-6">
      <div class="flex items-center gap-6 mb-6">
        <div class="text-center">
          <p class="font-mono text-4xl font-bold text-teal-400">0</p>
          <p class="text-xs text-slate-500 mt-1">Current streak</p>
        </div>
        <div class="text-center">
          <p class="font-mono text-4xl font-bold text-gold-400">0</p>
          <p class="text-xs text-slate-500 mt-1">Longest streak</p>
        </div>
      </div>
      <p class="text-sm text-slate-400">Start studying today to begin your streak.</p>
    </div>
  </section>
</DashboardLayout>
